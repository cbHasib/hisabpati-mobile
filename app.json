{
  "expo": {
    "name": "HisabPati",
    "slug": "hisabpati",
    "version": "1.0.0",
    "scheme": "hisabpati",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6C63FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hisabpati.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6C63FF"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.hisabpati.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset",
      "expo-secure-store",
      "expo-web-browser",
      "expo-localization",
      "expo-image"
    ]
  }
}
